{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VenoApp Bridge",
  "version": "1.0.17",
  "identifier": "com.venoapp.bridge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "VenoApp Bridge",
        "width": 420,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "title": "VenoApp Bridge",
      "tooltip": "VenoApp Bridge"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "autostart": {
      "windows": "Task Scheduler",
      "linux": "Systemd"
    }
  }
}
