{
  "name": "venoapp-bridge-node",
  "version": "1.0.0",
  "description": "VenoApp Bridge - Node.js server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:win": "pkg server.js --targets node18-win-x64 --output ../venoapp-bridge-win.exe --compress GZip",
    "build:linux": "pkg server.js --targets node18-linux-x64 --output ../venoapp-bridge-linux --compress GZip"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "selfsigned": "^2.4.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [],
    "targets": ["node18-win-x64", "node18-linux-x64"]
  }
}
